// 1. 주석 (Comments): 차분한 회색이 나와야 합니다.
/* Atom One Dark 테마 종합 테스트 파일입니다.
  각 요소들이 지정된 색상으로 잘 나오는지 확인해 보세요.
*/

// 2. 키워드(Keywords)와 변수(Variables): 보라색과 산호색(빨강)
const themeName = "Atom One Dark"; 
let isConfigured = true;

// 3. 문자열(Strings)과 숫자(Numbers): 연두색과 주황색
const version = 1.0;
const greetingMessage = '안녕하세요, VS Code 테마 테스트입니다!';

// 4. 데이터 타입(Types)과 함수(Functions): 노란색과 파란색
class ThemeTester {
  constructor(name) {
    this.name = name;
  }
  
  // 함수 및 메소드 테스트
  printStatus() {
    console.log(this.name + " 색상이 완벽하게 적용되었습니다.");
  }
}

// 5. 연산자(Operators)와 구두점(Punctuation): 청록색과 기본 텍스트 색상(회백색)
if (version >= 1.0 && isConfigured !== false) {
  const tester = new ThemeTester(themeName);
  tester.printStatus(); // 점(.)이나 괄호()는 튀지 않는 색상이어야 합니다.
}